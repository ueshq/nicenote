{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "generate:css": {
      "dependsOn": ["^build"],
      "outputs": ["dist/generated-tokens.css"]
    },
    "@nicenote/web#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "test": {
      "dependsOn": ["^test"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "@nicenote/mobile#start": {
      "cache": false,
      "persistent": true
    },
    "@nicenote/mobile#ios": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "@nicenote/mobile#android": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "@nicenote/editor-bridge#build:template": {
      "outputs": ["dist/generated/editor.html"],
      "dependsOn": ["^build"]
    },
    "@nicenote/desktop#build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "@nicenote/desktop#dev": {
      "cache": false,
      "persistent": true
    }
  }
}
